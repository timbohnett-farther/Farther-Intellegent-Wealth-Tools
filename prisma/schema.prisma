model relocation_estate_rules {
  id                      String   @id
  jurisdiction_id         String
  estate_tax_mode         String
  estate_exemption        Float?
  estate_rate_schedule_key String?
  inheritance_tax_mode    String   @default("none")
  inheritance_rule_key    String?
  active_from             String
  active_to               String?
  version                 Int      @default(1)
