  // Top-level results
  probabilityOfSuccess        Float    @map("probability_of_success")
  probabilityOfSuccessAdj     Float?   @map("probability_of_success_adj")

  // Monte Carlo outputs
  mcRuns                      Int      @map("mc_runs")
  mcMedianTerminalValue       Float    @map("mc_median_terminal_value")
  mcP10TerminalValue          Float    @map("mc_p10_terminal_value")
  mcP25TerminalValue          Float    @map("mc_p25_terminal_value")
  mcP75TerminalValue          Float    @map("mc_p75_terminal_value")
  mcP90TerminalValue          Float    @map("mc_p90_terminal_value")

  // Annual projections (JSON arrays)
  annualIncome                String?  @map("annual_income")
  annualExpenses              String?  @map("annual_expenses")
  annualTaxes                 String?  @map("annual_taxes")
  annualSavings               String?  @map("annual_savings")
  annualPortfolio             String?  @map("annual_portfolio")
  annualNetWorth              String?  @map("annual_net_worth")
  annualRmd                   String?  @map("annual_rmd")
  annualSsBenefit             String?  @map("annual_ss_benefit")
  annualCashFlow              String?  @map("annual_cash_flow")

  // Goal results
  goalResults                 String?  @map("goal_results") // JSON

  // Tax summary
  totalTaxesLifetime          Float?   @map("total_taxes_lifetime")
  avgEffectiveTaxRate         Float?   @map("avg_effective_tax_rate")
  peakTaxYear                 Int?     @map("peak_tax_year")
  peakTaxAmount               Float?   @map("peak_tax_amount")

  // Estate
  projectedEstateValue        Float?   @map("projected_estate_value")
  projectedEstateTaxDue       Float?   @map("projected_estate_tax_due")

  // Full result data (JSON blob with cash flows, percentile bands, roth conversions)
  resultData                  String?  @map("result_data")

  createdAt                   DateTime @default(now()) @map("created_at")

  plan                        Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  scenario                    Scenario? @relation(fields: [scenarioId], references: [id])

  @@index([planId])
  @@index([scenarioId])
  @@map("plan_results")
}

