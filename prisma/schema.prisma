  annualExpenses              String?  @map("annual_expenses")
  annualTaxes                 String?  @map("annual_taxes")
  annualSavings               String?  @map("annual_savings")
  annualPortfolio             String?  @map("annual_portfolio")
  annualNetWorth              String?  @map("annual_net_worth")
  annualRmd                   String?  @map("annual_rmd")
  annualSsBenefit             String?  @map("annual_ss_benefit")
  annualCashFlow              String?  @map("annual_cash_flow")

  // Goal results
