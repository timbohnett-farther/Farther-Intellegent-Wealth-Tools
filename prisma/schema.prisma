  is_leaving_state_enabled Boolean @default(false)
  tax_year                Int
  effective_date          String
  last_reviewed_at        String
  status                  String   @default("draft")
  source_set_id           String?
  notes_public            String?
  notes_internal          String?
  created_at              DateTime @default(now())
  updated_at              DateTime @default(now()) @updatedAt

  // Relations
  income_tax_rules        relocation_income_tax_rules[]
  estate_rules            relocation_estate_rules[]
  puerto_rico_rules       relocation_puerto_rico_rules?
  source_documents        relocation_source_documents[]

