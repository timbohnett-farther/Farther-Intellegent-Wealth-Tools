// ==================== STAGE 4: MARKET DATA ====================
model MarketDataSnapshot {
  id                  String   @id @default(cuid())
  date                DateTime
  dataType            String   @map("data_type") // daily_close | monthly_afr | annual_7520 | quarterly_irmaa

  sp500Price          Float?   @map("sp500_price")
  sp500YtdReturn      Float?   @map("sp500_ytd_return")
  tenYearTreasury     Float?   @map("ten_year_treasury")
  thirtyYearTreasury  Float?   @map("thirty_year_treasury")
  fedFundsRate        Float?   @map("fed_funds_rate")
  cpiYoy              Float?   @map("cpi_yoy")
  afrShortTerm        Float?   @map("afr_short_term")
  afrMidTerm          Float?   @map("afr_mid_term")
  afrLongTerm         Float?   @map("afr_long_term")
  sec7520Rate         Float?   @map("sec_7520_rate")

  rawData             String?  @map("raw_data") // JSON for any additional data
  source              String?

  createdAt           DateTime @default(now()) @map("created_at")

  @@unique([date, dataType])
  @@index([dataType, date])
  @@map("market_data_snapshots")
}

// ==================== STAGE 4: EMAIL DRAFTS ====================
model EmailDraft {
  id                  String   @id @default(cuid())
  planId              String?  @map("plan_id")
  insightId           String?  @map("insight_id")

  toEmail             String   @map("to_email")
  toName              String?  @map("to_name")
  fromEmail           String   @map("from_email")
  fromName            String?  @map("from_name")
  subject             String
  body                String

  status              String   @default("draft") // draft | sent | scheduled | cancelled
  scheduledAt         DateTime? @map("scheduled_at")
  sentAt              DateTime? @map("sent_at")
  generatedBy         String   @map("generated_by") // ai | manual

  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@map("email_drafts")
}

// ==================== TAX TABLES ====================
model TaxTable {
  id              String   @id @default(cuid())
  taxYear         Int      @map("tax_year")
  tableType       String   @map("table_type")
  filingStatus    String?  @map("filing_status")
  data            String   // JSON
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([taxYear, tableType, filingStatus])
  @@map("tax_tables")
}

// ==================== TAX INTELLIGENCE PLATFORM ====================
// Phase 1: Core Models (6 new models + 3 extensions)

model TaxDocument {
  id                String   @id @default(cuid())
  householdId       String   @map("household_id")
  household         Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  documentType      String   // "1040" | "W-2" | "1099-DIV" | "Schedule_D" | "K-1_1065" | etc.
  taxYear           Int?     @map("tax_year") // Nullable until classified
  originalFilename  String   @map("original_filename")
  uploadedAt        DateTime @default(now()) @map("uploaded_at")
  uploadedBy        String   @map("uploaded_by") // advisorId
  uploadedByAdvisor Advisor  @relation(fields: [uploadedBy], references: [id])

  // Storage
  fileUrl           String   @map("file_url")
  fileSize          Int      @map("file_size")
  contentType       String   @map("content_type")
  fileHash          String?  @map("file_hash") // SHA-256 for duplicate detection

  // Phase 2: Processing Pipeline Status
  processingStatus  String   @default("uploaded") @map("processing_status") // "uploaded" | "queued" | "processing" | "ocr_complete" | "classified" | "fields_extracted" | "needs_review" | "approved" | "rejected" | "failed"

  // OCR processing
  ocrStatus         String   @default("pending") @map("ocr_status") // "pending" | "processing" | "completed" | "failed" | "review_needed"
  ocrProvider       String?  @map("ocr_provider") // "azure"
  ocrProcessedAt    DateTime? @map("ocr_processed_at")
  ocrConfidence     Float?   @map("ocr_confidence")
  ocrRawJson        String?  @map("ocr_raw_json") // Raw OCR output for debugging

  // Phase 2: Classification
  classificationConfidence Float? @map("classification_confidence")
  classificationMethod     String? @map("classification_method") // "rules" | "layout" | "ai"
  classificationReason     String? @map("classification_reason") // Why it chose this type
  alternativeTypes         String? @map("alternative_types") // JSON: fallback options
  taxpayerName             String? @map("taxpayer_name")
  spouseName               String? @map("spouse_name")

  // Phase 2: Page Management
  pageCount         Int?     @map("page_count")
  hasTextLayer      Boolean  @default(false) @map("has_text_layer")

  // Human review
  reviewStatus      String   @default("pending") @map("review_status") // "pending" | "in_review" | "approved" | "rejected"
  reviewedAt        DateTime? @map("reviewed_at")
  reviewedBy        String?  @map("reviewed_by")
  reviewNotes       String?  @map("review_notes")

  // Phase 2: Error Handling
  processingError   String?  @map("processing_error")
  retryCount        Int      @default(0) @map("retry_count")
  lastRetryAt       DateTime? @map("last_retry_at")

  // Data lineage
  sourcePagesMap    String?  @map("source_pages_map") // JSON: { "wages": [1, 2], "dividends": [3] }

  // Relations
  extractedForms    TaxForm[]
  documentPages     DocumentPage[]
  extractedFields   ExtractedField[]
  auditLogs         AuditLog[]

  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@index([householdId, taxYear])
  @@index([ocrStatus])
  @@index([reviewStatus])
  @@index([processingStatus])
  @@index([fileHash])
  @@map("tax_documents")
}

model TaxForm {
  id              String   @id @default(cuid())
  documentId      String   @map("document_id")
  document        TaxDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  householdId     String   @map("household_id")
  household       Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  formType        String   @map("form_type") // "1040" | "W-2" | "1099-DIV" | "Schedule_A" | "K-1_1065" | etc.
  taxYear         Int      @map("tax_year")

  // Line-by-line data with confidence (JSON)
  fieldData       String   @map("field_data") // { "line_1_wages": { value: 150000, confidence: 0.98, sourcePage: 1 }, ... }

  // Computed aggregates (from fieldData, NEVER from AI)
  agi             Float?
  totalIncome     Float?   @map("total_income")
  adjustments     Float?
  deductions      Float?
  taxableIncome   Float?   @map("taxable_income")
  totalTax        Float?   @map("total_tax")

  // Versioning (immutable)
  checksum        String?
  version         Int      @default(1)
  supersededBy    String?  @map("superseded_by")

  extractedAt     DateTime @default(now()) @map("extracted_at")
  verifiedAt      DateTime? @map("verified_at")
  verifiedBy      String?  @map("verified_by")

  scenarios       TaxScenario[] @relation("BaselineForm")
  auditLogs       AuditLog[]

  @@index([householdId, taxYear, formType])
  @@index([documentId])
  @@map("tax_forms")
}

model TaxScenario {
  id              String   @id @default(cuid())
  householdId     String   @map("household_id")
  household       Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  planId          String?  @map("plan_id")
  plan            Plan?    @relation(fields: [planId], references: [id], onDelete: SetNull)

  name            String
  type            String   // "baseline" | "opportunity" | "what_if" | "multi_year"
  description     String?
  taxYear         Int      @map("tax_year")

  baselineFormId  String?  @map("baseline_form_id")
  baselineForm    TaxForm? @relation("BaselineForm", fields: [baselineFormId], references: [id], onDelete: SetNull)

  // Scenario inputs (overrides to baseline)
  adjustments     String   // JSON: { "rothConversion": 50000, "charitableGift": 10000, ... }

  // Computed results (DETERMINISTIC calculation)
  results         String   // JSON: { federal: {...}, state: {...}, summary: {...} }

  // Comparison to baseline
  vsBaseline      String?  @map("vs_baseline") // JSON: { taxSavings: -5000, effectiveRateChange: -1.2, ... }

  calculationEngine String @default("v1") @map("calculation_engine")
  calculatedAt    DateTime @default(now()) @map("calculated_at")
  calculatedBy    String?  @map("calculated_by")

  status          String   @default("draft") // "draft" | "published" | "archived"
  publishedAt     DateTime? @map("published_at")

  opportunities   TaxOpportunity[]
  deliverables    TaxDeliverable[]
  auditLogs       AuditLog[]

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  createdBy       String   @map("created_by")

  @@index([householdId, taxYear])
  @@index([planId])
  @@index([status])
  @@map("tax_scenarios")
}

model TaxOpportunity {
  id              String   @id @default(cuid())
  householdId     String   @map("household_id")
  household       Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  scenarioId      String?  @map("scenario_id")
  scenario        TaxScenario? @relation(fields: [scenarioId], references: [id], onDelete: SetNull)

  category        String   // "roth_conversion" | "cap_gains_mgmt" | "charitable_gifting" | "niit_planning" | "withholding" | "rmd_sequencing"
  priority        String   // "high" | "medium" | "low"
  status          String   @default("identified") @map("status") // "identified" | "reviewed" | "recommended" | "in_progress" | "implemented" | "dismissed"

  detectedAt      DateTime @default(now()) @map("detected_at")
  detectedBy      String   @default("system") @map("detected_by")
  detectionLogic  String?  @map("detection_logic")

  title           String
  description     String
  estimatedValue  Float?   @map("estimated_value")
  confidence      String   // "high" | "medium" | "low"

  analysisData    String   @map("analysis_data") // JSON: { currentAgi: 150000, marginalRate: 0.24, conversionSpace: 50000, ... }

  // AI-generated content (with citations)
  aiSummary       String?  @map("ai_summary")
  aiCitations     String?  @map("ai_citations") // JSON: [{ source: "IRS Pub 590-B", section: "..." }]
  aiGeneratedAt   DateTime? @map("ai_generated_at")

  // Workflow
  recommendedAt   DateTime? @map("recommended_at")
  recommendedBy   String?  @map("recommended_by")
  implementedAt   DateTime? @map("implemented_at")
  implementedBy   String?  @map("implemented_by")
  dismissedAt     DateTime? @map("dismissed_at")
  dismissedReason String?  @map("dismissed_reason")

  deliverables    TaxDeliverable[]
  auditLogs       AuditLog[]

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([householdId, category])
  @@index([status])
  @@index([priority])
  @@map("tax_opportunities")
}

model TaxDeliverable {
  id              String   @id @default(cuid())
  householdId     String   @map("household_id")
  household       Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  scenarioId      String?  @map("scenario_id")
  scenario        TaxScenario? @relation(fields: [scenarioId], references: [id], onDelete: SetNull)
  opportunityId   String?  @map("opportunity_id")
  opportunity     TaxOpportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)

  type            String   // "tax_snapshot" | "client_letter" | "advisor_summary" | "scenario_comparison" | "cpa_memo"
  format          String   // "pdf" | "docx"

  generatedAt     DateTime @default(now()) @map("generated_at")
  generatedBy     String   @map("generated_by")
  generationInputs String  @map("generation_inputs") // JSON snapshot

  version         Int      @default(1)
  supersededBy    String?  @map("superseded_by")

  fileUrl         String?  @map("file_url")
  fileSize        Int?     @map("file_size")
  checksum        String?

  title           String
  summary         String?

  containsPHI     Boolean  @default(true) @map("contains_phi")
  retentionPolicy String   @default("7_years") @map("retention_policy")

  status          String   @default("draft") // "draft" | "finalized" | "sent" | "archived"
  finalizedAt     DateTime? @map("finalized_at")
  sentAt          DateTime? @map("sent_at")
  sentTo          String?  @map("sent_to")

  auditLogs       AuditLog[]

  @@index([householdId, type])
  @@index([scenarioId])
  @@index([status])
  @@map("tax_deliverables")
}

model AuditLog {
  id              String   @id @default(cuid())

  entityType      String   @map("entity_type") // "TaxDocument" | "TaxForm" | "TaxScenario" | "TaxOpportunity" | "TaxDeliverable"
  entityId        String   @map("entity_id")

  documentId      String?  @map("document_id")
  document        TaxDocument? @relation(fields: [documentId], references: [id], onDelete: Cascade)
  formId          String?  @map("form_id")
  form            TaxForm? @relation(fields: [formId], references: [id], onDelete: Cascade)
  scenarioId      String?  @map("scenario_id")
  scenario        TaxScenario? @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  opportunityId   String?  @map("opportunity_id")
  opportunity     TaxOpportunity? @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  deliverableId   String?  @map("deliverable_id")
  deliverable     TaxDeliverable? @relation(fields: [deliverableId], references: [id], onDelete: Cascade)

  action          String   // "created" | "updated" | "deleted" | "ocr_processed" | "reviewed" | "approved" | "calculated" | "sent"
  actor           String   // advisorId or "system"
  actorType       String   @map("actor_type") // "advisor" | "system" | "client"

  changesBefore   String?  @map("changes_before") // JSON snapshot
  changesAfter    String?  @map("changes_after") // JSON snapshot
  metadata        String?  // JSON: { reason: "...", notes: "..." }

  timestamp       DateTime @default(now())

  ipAddress       String?  @map("ip_address")
  userAgent       String?  @map("user_agent")
  sessionId       String?  @map("session_id")

  @@index([entityType, entityId])
  @@index([documentId])
  @@index([formId])
  @@index([scenarioId])
  @@index([actor])
  @@index([timestamp])
  @@map("audit_logs")
}

// ==================== PHASE 2: INTAKE & REVIEW MODELS ====================
// Sprint 1-6 Models: Document pages, extracted fields, approved facts, review actions

model DocumentPage {
  id              String   @id @default(cuid())
  documentId      String   @map("document_id")
  document        TaxDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  pageNumber      Int      @map("page_number")
  pageImageUrl    String?  @map("page_image_url") // Rendered page image
  thumbnailUrl    String?  @map("thumbnail_url")

  // OCR Results
  rawText         String?  @map("raw_text") // Full page text
  textLayerJson   String?  @map("text_layer_json") // Coordinate-mapped text
  ocrConfidence   Float?   @map("ocr_confidence")

  // Layout Analysis
  layoutType      String?  @map("layout_type") // "form" | "statement" | "letter" | "table"
  detectedFields  String?  @map("detected_fields") // JSON: preliminary field locations

  // Preprocessing
  isRotated       Boolean  @default(false) @map("is_rotated")
  rotationDegrees Int?     @map("rotation_degrees")
  isDeskewed      Boolean  @default(false) @map("is_deskewed")

  width           Int?
  height          Int?

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  extractedFields ExtractedField[]

  @@index([documentId, pageNumber])
  @@map("document_pages")
}

model ExtractedField {
  id              String   @id @default(cuid())

  // Source linkage
  documentId      String   @map("document_id")
  document        TaxDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  pageId          String?  @map("page_id")
  page            DocumentPage? @relation(fields: [pageId], references: [id], onDelete: SetNull)
  householdId     String   @map("household_id")

  // Field identity
  formType        String   @map("form_type") // "1040" | "W-2" | "1099-DIV" | etc.
  taxYear         Int      @map("tax_year")
  fieldName       String   @map("field_name") // Canonical field name (e.g., "qualified_dividends")
  fieldLabel      String?  @map("field_label") // Display label (e.g., "Qualified Dividends")

  // Extracted values
  rawValue        String?  @map("raw_value") // As extracted from OCR
  normalizedValue String?  @map("normalized_value") // Cleaned/parsed value
  valueType       String   @map("value_type") // "currency" | "integer" | "text" | "date" | "boolean"

  // Source provenance
  pageNumber      Int?     @map("page_number")
  sourceBbox      String?  @map("source_bbox") // JSON: {x, y, width, height}
  sourceSnippet   String?  @map("source_snippet") // Text snippet showing context

  // Confidence & Quality
  extractionMethod String  @map("extraction_method") // "rules" | "layout" | "ocr" | "ai"
  confidenceScore Float    @map("confidence_score") // 0.0 to 1.0
  confidenceTier  String   @map("confidence_tier") // "high" | "medium" | "low"

  // Status & Review
  status          String   @default("extracted") @map("status") // "extracted" | "approved" | "edited" | "rejected" | "uncertain"
  reviewedAt      DateTime? @map("reviewed_at")
  reviewedBy      String?  @map("reviewed_by")

  // Linking to approved fact
  approvedFactId  String?  @map("approved_fact_id")
  approvedFact    ApprovedFact? @relation(fields: [approvedFactId], references: [id], onDelete: SetNull)

  // Versioning
  supersededBy    String?  @map("superseded_by") // If this extraction was replaced

  extractedAt     DateTime @default(now()) @map("extracted_at")

  reviewActions   ReviewAction[]

  @@index([householdId, taxYear])
  @@index([documentId, formType])
  @@index([fieldName, taxYear])
  @@index([confidenceTier])
  @@index([status])
  @@map("extracted_fields")
}

model ApprovedFact {
  id              String   @id @default(cuid())
  householdId     String   @map("household_id")
  household       Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  // Canonical field identity
  canonicalField  String   @map("canonical_field") // From taxonomy: "agi" | "qualified_dividends" | "filing_status" | etc.
  fieldCategory   String   @map("field_category") // "income" | "deductions" | "retirement" | "identity" | etc.

  // Value
  value           String   // Stored as string, type indicates interpretation
  valueType       String   @map("value_type") // "currency" | "integer" | "text" | "date" | "boolean"
  taxYear         Int      @map("tax_year")

  // Source tracking
  sourceFieldIds  String   @map("source_field_ids") // JSON array of ExtractedField IDs
  sourceSummary   String?  @map("source_summary") // Human-readable source description

  // Approval metadata
  approvalStatus  String   @default("approved") @map("approval_status") // "approved" | "provisional" | "disputed"
  approvedBy      String   @map("approved_by") // advisorId
  approvedAt      DateTime @default(now()) @map("approved_at")

  // Confidence rollup
  confidenceScore Float?   @map("confidence_score") // Aggregate from source fields

  // Notes & Context
  notes           String?
  context         String? // Additional context (e.g., "includes W-2 + 1099 income")

  // Versioning
  version         Int      @default(1)
  supersededBy    String?  @map("superseded_by")
  supersededAt    DateTime? @map("superseded_at")

  // Relations
  sourceFields    ExtractedField[]
  conflicts       ConflictRecord[] @relation("ConflictedFacts")

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([householdId, taxYear])
  @@index([canonicalField, taxYear])
  @@index([fieldCategory])
  @@index([approvalStatus])
  @@map("approved_facts")
}

model ReviewAction {
  id              String   @id @default(cuid())

  // What was reviewed
  extractedFieldId String  @map("extracted_field_id")
  extractedField  ExtractedField @relation(fields: [extractedFieldId], references: [id], onDelete: Cascade)

  // Action taken
  action          String   // "approved" | "edited" | "rejected" | "marked_uncertain" | "requested_second_review" | "merged" | "suppressed"

  // Actor
  reviewerId      String   @map("reviewer_id")
  reviewerName    String?  @map("reviewer_name")

  // Changes
  valueBefore     String?  @map("value_before")
  valueAfter      String?  @map("value_after")
  reason          String?
  notes           String?

  // Context
  ipAddress       String?  @map("ip_address")
  userAgent       String?  @map("user_agent")

  timestamp       DateTime @default(now())

  @@index([extractedFieldId])
  @@index([reviewerId])
  @@index([action])
  @@index([timestamp])
  @@map("review_actions")
}

model ConflictRecord {
  id              String   @id @default(cuid())
  householdId     String   @map("household_id")
  household       Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  // Conflict type
  conflictType    String   @map("conflict_type") // "duplicate_value" | "year_mismatch" | "logical_inconsistency" | "missing_schedule" | "staleness" | "name_mismatch"
  severity        String   // "critical" | "warning" | "info"

  // What conflicts
  fieldName       String?  @map("field_name")
  taxYear         Int?     @map("tax_year")

  // Conflicting facts
  fact1Id         String?  @map("fact_1_id")
  fact1           ApprovedFact? @relation("ConflictedFacts", fields: [fact1Id], references: [id], onDelete: SetNull)
  fact2Id         String?  @map("fact_2_id")

  // Description
  title           String
  description     String
  suggestion      String? // How to resolve

  // Resolution
  status          String   @default("open") // "open" | "reviewing" | "resolved" | "dismissed"
  resolvedAt      DateTime? @map("resolved_at")
  resolvedBy      String?  @map("resolved_by")
  resolutionNotes String?  @map("resolution_notes")

  detectedAt      DateTime @default(now()) @map("detected_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([householdId, status])
  @@index([conflictType])
  @@index([severity])
  @@map("conflict_records")
}

model MissingDataItem {
  id              String   @id @default(cuid())
  householdId     String   @map("household_id")
  household       Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  // What's missing
  itemType        String   @map("item_type") // "document" | "field" | "schedule"
  itemName        String   @map("item_name") // "prior_year_return" | "spouse_w2" | "schedule_d"
  itemCategory    String   @map("item_category") // "income" | "deductions" | "retirement" | "identity"

  // Context
  taxYear         Int?     @map("tax_year")
  priority        String   @default("medium") // "critical" | "high" | "medium" | "low"
  reason          String   // Why it's needed

  // Status
  status          String   @default("missing") // "missing" | "requested" | "received" | "dismissed"
  requestedAt     DateTime? @map("requested_at")
  receivedAt      DateTime? @map("received_at")
  dismissedAt     DateTime? @map("dismissed_at")

  notes           String?

  detectedAt      DateTime @default(now()) @map("detected_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([householdId, status])
  @@index([itemType])
  @@index([priority])
  @@map("missing_data_items")
}

// ==================== PHASE 3: DETERMINISTIC TAX CALCULATION ENGINE ====================
// Sprint 1-10 Models: Input snapshots, validation, rules, calculation runs, traces, scenarios, comparisons

model TaxInputSnapshot {
  id                    String   @id @default(cuid())
  householdId           String   @map("household_id")
  household             Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  taxYear               Int      @map("tax_year")
  filingStatus          String   @map("filing_status") // "single" | "married_filing_jointly" | etc.

  // Taxpayer information
  taxpayers             String   // JSON: Taxpayer[]

  // Complete tax inputs (JSON serialization of TaxInputs interface)
  inputs                String   // JSON: all income, deductions, credits, payments

  // Data quality
  missingInputs         String?  @map("missing_inputs") // JSON: string[]
  warnings              String?  // JSON: string[]

  // Data lineage
  sourceFactVersions    String   @map("source_fact_versions") // JSON: Record<string, number>

  // Approval
  approvedBy            String?  @map("approved_by")
  approvedAt            DateTime? @map("approved_at")

  // Relations
  validations           TaxInputValidation[]
  calculationRuns       CalculationRun[]

  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@index([householdId, taxYear])
  @@index([filingStatus])
  @@map("tax_input_snapshots")
}

model TaxInputValidation {
  id                    String   @id @default(cuid())
  snapshotId            String   @map("snapshot_id")
  snapshot              TaxInputSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  pass                  Boolean
  canProceed            Boolean  @map("can_proceed") // false if any hard_fail

  // Summary stats
  totalRules            Int      @map("total_rules")
  passCount             Int      @map("pass_count")
  passWithWarningCount  Int      @map("pass_with_warning_count")
  softFailCount         Int      @map("soft_fail_count")
  hardFailCount         Int      @map("hard_fail_count")

  // Violations
  violations            String   // JSON: ValidationViolation[]

  validatedAt           DateTime @default(now()) @map("validated_at")

  @@index([snapshotId])
  @@index([canProceed])
  @@map("tax_input_validations")
}

model TaxRulesPackage {
  id                    String   @id @default(cuid())

  rulesVersion          String   @unique @map("rules_version") // "2025_federal_v1"
  taxYear               Int      @map("tax_year")
  jurisdiction          String   @default("federal") // "federal" | "state:CA" | etc.

  // Complete rules JSON (TaxRulesPackage interface)
  rulesJson             String   @map("rules_json")

  // Integrity
  checksum              String   // SHA-256 of rulesJson

  // Metadata
  publishedAt           DateTime @map("published_at")
  publishedBy           String   @map("published_by")
  isActive              Boolean  @default(true) @map("is_active")

  // Relations
  calculationRuns       CalculationRun[]

  createdAt             DateTime @default(now()) @map("created_at")

  @@index([taxYear, jurisdiction, isActive])
  @@map("tax_rules_packages")
}

model CalculationRun {
  id                    String   @id @default(cuid())

  // Input
  snapshotId            String   @map("snapshot_id")
  snapshot              TaxInputSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  householdId           String   @map("household_id")
  taxYear               Int      @map("tax_year")

  // Rules
  rulesVersion          String   @map("rules_version")
  rulesPackage          TaxRulesPackage @relation(fields: [rulesVersion], references: [rulesVersion])

  // Run type
  runType               String   @map("run_type") // "baseline" | "scenario"

  // Output
  outputSnapshotId      String   @unique @map("output_snapshot_id")
  outputSnapshot        TaxOutputSnapshot @relation(fields: [outputSnapshotId], references: [id], onDelete: Cascade)

  // Metadata
  outputHash            String   @map("output_hash") // SHA-256
  computeTimeMs         Int      @map("compute_time_ms")
  warningCount          Int      @default(0) @map("warning_count")

  // Supersede chain
  supersededBy          String?  @map("superseded_by")
  supersededAt          DateTime? @map("superseded_at")
  supersededReason      String?  @map("superseded_reason") // "fact_update" | "rules_update" | "manual_recalc"

  // Relations
  trace                 CalculationTrace?
  scenarioRuns          ScenarioRun[] @relation("BaselineRun")
  comparisons           RunComparison[] @relation("BaselineComparisons")
  scenarioComparisons   RunComparison[] @relation("ScenarioComparisons")
  recommendationSignals RecommendationSignals?
  auditEvents           CalculationAuditEvent[]
  opportunityDetectionRuns OpportunityDetectionRun[]

  createdAt             DateTime @default(now()) @map("created_at")

  @@index([householdId, taxYear])
  @@index([runType])
  @@index([rulesVersion])
  @@index([supersededBy])
  @@map("calculation_runs")
}

model TaxOutputSnapshot {
  id                    String   @id @default(cuid())

  // Complete output (TaxOutput interface)
  summaryJson           String   @map("summary_json") // TaxSummary
  incomeBreakdownJson   String   @map("income_breakdown_json")
  deductionBreakdownJson String  @map("deduction_breakdown_json")
  taxCalculationJson    String   @map("tax_calculation_json")
  creditsJson           String   @map("credits_json")
  paymentsJson          String   @map("payments_json")

  // Quick access fields (denormalized for query performance)
  agi                   Float
  taxableIncome         Float    @map("taxable_income")
  totalTax              Float    @map("total_tax")
  refundOrBalanceDue    Float    @map("refund_or_balance_due")
  effectiveTaxRate      Float    @map("effective_tax_rate")
  marginalTaxRate       Float    @map("marginal_tax_rate")

  // Warnings
  warnings              String?  // JSON: string[]

  // Relations
  calculationRun        CalculationRun?

  createdAt             DateTime @default(now()) @map("created_at")

  @@index([agi])
  @@index([totalTax])
  @@map("tax_output_snapshots")
}

model CalculationTrace {
  id                    String   @id @default(cuid())
  runId                 String   @unique @map("run_id")
  run                   CalculationRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  // Trace steps (TraceStep[])
  stepsJson             String   @map("steps_json")
  totalSteps            Int      @map("total_steps")

  completedAt           DateTime @default(now()) @map("completed_at")

  @@index([runId])
  @@map("calculation_traces")
}

model ScenarioOverrideSet {
  id                    String   @id @default(cuid())
  householdId           String   @map("household_id")
  taxYear               Int      @map("tax_year")

  name                  String
  description           String?

  // Overrides (ScenarioOverride[])
  overridesJson         String   @map("overrides_json")

  // Metadata
  createdBy             String   @map("created_by")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  // Relations
  scenarioRuns          ScenarioRun[]

  @@index([householdId, taxYear])
  @@map("scenario_override_sets")
}

model ScenarioRun {
  id                    String   @id @default(cuid())

  // Links
  baselineRunId         String   @map("baseline_run_id")
  baselineRun           CalculationRun @relation("BaselineRun", fields: [baselineRunId], references: [id], onDelete: Cascade)

  overrideSetId         String   @map("override_set_id")
  overrideSet           ScenarioOverrideSet @relation(fields: [overrideSetId], references: [id], onDelete: Cascade)

  scenarioRunId         String   @map("scenario_run_id") // Points to CalculationRun with runType="scenario"

  // Context
  householdId           String   @map("household_id")
  taxYear               Int      @map("tax_year")

  createdAt             DateTime @default(now()) @map("created_at")

  @@index([baselineRunId])
  @@index([overrideSetId])
  @@index([householdId, taxYear])
  @@map("scenario_runs")
}

model RunComparison {
  id                    String   @id @default(cuid())

  // Runs being compared
  baselineRunId         String   @map("baseline_run_id")
  baselineRun           CalculationRun @relation("BaselineComparisons", fields: [baselineRunId], references: [id], onDelete: Cascade)

  scenarioRunId         String   @map("scenario_run_id")
  scenarioRun           CalculationRun @relation("ScenarioComparisons", fields: [scenarioRunId], references: [id], onDelete: Cascade)

  // Context
  householdId           String   @map("household_id")
  taxYear               Int      @map("tax_year")

  // Summary diff
  summaryDiffJson       String   @map("summary_diff_json") // Quick deltas (AGI, tax, etc.)

  // Field-by-field diffs (FieldDiff[])
  fieldDiffsJson        String   @map("field_diffs_json")

  // Interpretation tags
  interpretations       String   // JSON: InterpretationTag[]

  // AI narrative
  narrative             String?
  narrativeGeneratedAt  DateTime? @map("narrative_generated_at")

  createdAt             DateTime @default(now()) @map("created_at")

  @@index([baselineRunId, scenarioRunId])
  @@index([householdId, taxYear])
  @@map("run_comparisons")
}

model RecommendationSignals {
  id                    String   @id @default(cuid())
  runId                 String   @unique @map("run_id")
  run                   CalculationRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  householdId           String   @map("household_id")
  taxYear               Int      @map("tax_year")

  // Complete signals (RecommendationSignals interface)
  signalsJson           String   @map("signals_json")

  // Quick access flags (denormalized)
  niitApplies           Boolean  @map("niit_applies")
  irmaaB1               Boolean  @map("irmaa_b1")
  estimatedTaxShortfall Float?   @map("estimated_tax_shortfall")

  computedAt            DateTime @default(now()) @map("computed_at")

  @@index([runId])
  @@index([householdId, taxYear])
  @@map("recommendation_signals")
}

model CalculationAuditEvent {
  id                    String   @id @default(cuid())

  eventId               String   @unique @map("event_id")
  eventType             String   @map("event_type") // "calculation_run.completed" | "calculation_run.superseded" | etc.

  // Related run
  runId                 String?  @map("run_id")
  run                   CalculationRun? @relation(fields: [runId], references: [id], onDelete: SetNull)

  // Event payload
  payloadJson           String   @map("payload_json")

  // Metadata
  source                String   @default("tax-engine")
  triggeredBy           String?  @map("triggered_by")

  timestamp             DateTime @default(now())

  @@index([eventType])
  @@index([runId])
  @@index([timestamp])
  @@map("calculation_audit_events")
}

// ==================== PHASE 4: OPPORTUNITY DETECTION ENGINE ====================
// Sprint 1-7 Models: Opportunity detection runs, opportunities, audit events, rules

model OpportunityDetectionRun {
  id                  String   @id @default(cuid())

  // Input linkage
  calculationRunId    String   @map("calculation_run_id")
  calculationRun      CalculationRun @relation(fields: [calculationRunId], references: [id], onDelete: Cascade)
  householdId         String   @map("household_id")
  household           Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  taxYear             Int      @map("tax_year")

  // Run metadata
  rulesVersion        String   @map("rules_version") // Which rule package was used
  totalRulesEvaluated Int      @map("total_rules_evaluated")
  totalRulesPassed    Int      @map("total_rules_passed")

  // Results summary
  opportunitiesDetected Int    @map("opportunities_detected")
  highPriorityCount     Int    @map("high_priority_count")
  estimatedValueTotal   Float? @map("estimated_value_total")

  // Performance
  computeTimeMs       Int      @map("compute_time_ms")

  // Status
  status              String   @default("completed") // "running" | "completed" | "failed"
  error               String?

  // Relations
  opportunities       Opportunity[]
  auditEvents         OpportunityAuditEvent[]

  completedAt         DateTime @default(now()) @map("completed_at")
  createdAt           DateTime @default(now()) @map("created_at")

  @@index([householdId, taxYear])
  @@index([calculationRunId])
  @@index([rulesVersion])
  @@index([status])
  @@map("opportunity_detection_runs")
}

model Opportunity {
  id                  String   @id @default(cuid())

  // Linkage
  detectionRunId      String   @map("detection_run_id")
  detectionRun        OpportunityDetectionRun @relation(fields: [detectionRunId], references: [id], onDelete: Cascade)
  householdId         String   @map("household_id")
  household           Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  taxYear             Int      @map("tax_year")

  // Rule that detected this
  ruleName            String   @map("rule_name")
  ruleVersion         String   @map("rule_version")

  // Classification
  category            String   // "roth_conversion" | "irmaa" | "withholding" | "tax_loss_harvest" | "bunching" | etc.
  subcategory         String?

  // Ranking
  priority            String   // "high" | "medium" | "low"
  rank                Int      // Within household+year, 1 = top opportunity

  // Core fields
  title               String
  summary             String
  estimatedValue      Float?   @map("estimated_value")
  confidence          String   // "high" | "medium" | "low"

  // Evidence (JSON: Evidence[])
  evidenceJson        String   @map("evidence_json")

  // Composite scoring (JSON: CompositeScore)
  scoreJson           String   @map("score_json")
  finalScore          Float    @map("final_score") // Denormalized for sorting

  // Context (JSON: contextual data from rule evaluation)
  contextJson         String   @map("context_json")

  // Suppression & Deduplication
  isDuplicate         Boolean  @default(false) @map("is_duplicate")
  duplicateOfId       String?  @map("duplicate_of_id")
  suppressionReason   String?  @map("suppression_reason")

  // Workflow
  status              String   @default("detected") // "detected" | "reviewed" | "recommended" | "dismissed" | "implemented"
  reviewedAt          DateTime? @map("reviewed_at")
  reviewedBy          String?  @map("reviewed_by")
  dismissedAt         DateTime? @map("dismissed_at")
  dismissedReason     String?  @map("dismissed_reason")
  implementedAt       DateTime? @map("implemented_at")

  // AI enhancement
  aiSummary           String?  @map("ai_summary")
  aiGeneratedAt       DateTime? @map("ai_generated_at")

  // Relations
  auditEvents         OpportunityAuditEvent[]

  // Phase 5: Scenario Planning Workspace relations
  planningScenarios   PlanningScenario[]

  detectedAt          DateTime @default(now()) @map("detected_at")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@index([householdId, taxYear])
  @@index([detectionRunId])
  @@index([category])
  @@index([priority, rank])
  @@index([status])
  @@index([isDuplicate])
  @@map("opportunities")
}

model OpportunityAuditEvent {
  id                  String   @id @default(cuid())

  eventId             String   @unique @map("event_id")
  eventType           String   @map("event_type") // "opportunity.detected" | "opportunity.reviewed" | "opportunity.dismissed" | etc.

  // Related opportunity
  opportunityId       String?  @map("opportunity_id")
  opportunity         Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)

  // Related detection run
  detectionRunId      String?  @map("detection_run_id")
  detectionRun        OpportunityDetectionRun? @relation(fields: [detectionRunId], references: [id], onDelete: SetNull)

  // Event payload (JSON)
  payloadJson         String   @map("payload_json")

  // Metadata
  source              String   @default("opportunity-engine")
  triggeredBy         String?  @map("triggered_by")

  timestamp           DateTime @default(now())

  @@index([eventType])
  @@index([opportunityId])
  @@index([detectionRunId])
  @@index([timestamp])
  @@map("opportunity_audit_events")
}

model OpportunityRule {
  id                  String   @id @default(cuid())

  // Rule identity
  ruleName            String   @unique @map("rule_name")
  ruleVersion         String   @map("rule_version")
  category            String

  // Metadata
  title               String
  description         String

  // Rule definition (JSON: complete rule package)
  ruleDefinitionJson  String   @map("rule_definition_json")

  // Control
  isActive            Boolean  @default(true) @map("is_active")
  priority            Int      @default(50) // Higher = evaluated first

  // Author
  createdBy           String   @map("created_by")
  publishedAt         DateTime @map("published_at")

  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@index([category])
  @@index([isActive, priority])
  @@map("opportunity_rules")
}

// ==================== PHASE 5: SCENARIO PLANNING WORKSPACE ====================

model PlanningScenario {
  id                  String   @id @default(cuid())

  // Household and tax year context
  householdId         String   @map("household_id")
  household           Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  planId              String?  @map("plan_id")
  plan                Plan?    @relation(fields: [planId], references: [id], onDelete: SetNull)
  taxYear             Int      @map("tax_year")

  // Baseline references
  baselineSnapshotId  String   @map("baseline_snapshot_id")
  baselineRunId       String   @map("baseline_run_id")

  // Scenario references
  scenarioSnapshotId  String   @map("scenario_snapshot_id")
  scenarioRunId       String   @map("scenario_run_id")

  // Scenario metadata
  scenarioType        String   @map("scenario_type") // "roth_conversion" | "charitable" | "capital_gains" | "payments" | "retirement_income" | "transition" | "custom"
  title               String
  description         String?

  // Origin tracking
  originatingOpportunityId String? @map("originating_opportunity_id")
  opportunity         Opportunity? @relation(fields: [originatingOpportunityId], references: [id], onDelete: SetNull)

  // Scenario data (JSON fields)
  overridesJson       String   @map("overrides_json") // Array of ScenarioOverride
  assumptionsJson     String   @map("assumptions_json") // Array of ScenarioAssumption
  warningsJson        String   @map("warnings_json") // Array of warning strings
  blockersJson        String?  @map("blockers_json") // Array of MissingInfoItem (optional)

  // Notes
  notes               String?

  // Lifecycle
  status              String   @default("draft") // "draft" | "ready_for_review" | "reviewed" | "recommended" | "presented" | "archived" | "superseded"
  recommended         Boolean  @default(false)

  // Versioning
  version             Int      @default(1)
  supersededBy        String?  @map("superseded_by")

  // Attribution
  createdBy           String   @map("created_by")
  publishedAt         DateTime? @map("published_at")

  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  // Relations
  notes_relation      ScenarioNote[]
  auditEvents         ScenarioAuditEvent[]
  comparisonsAsBaseline ScenarioComparison[] @relation("BaselineScenario")
  comparisonsAsComparison ScenarioComparison[] @relation("ComparisonScenarios")
  calculationRuns     TaxCalculationRun[]

  @@index([householdId, taxYear])
  @@index([planId])
  @@index([status])
  @@index([recommended])
  @@index([originatingOpportunityId])
  @@map("planning_scenarios")
}

model ScenarioNote {
  id                  String   @id @default(cuid())
  scenarioId          String   @map("scenario_id")
  scenario            PlanningScenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  noteType            String   @map("note_type") // "advisor_internal" | "meeting_prep" | "assumption" | "compliance"
  body                String

  createdBy           String   @map("created_by")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@index([scenarioId])
  @@index([noteType])
  @@map("scenario_notes")
}

model ScenarioComparison {
  id                  String   @id @default(cuid())

  // Context
  householdId         String   @map("household_id")
  taxYear             Int      @map("tax_year")

  // Baseline
  baselineScenarioId  String   @map("baseline_scenario_id")
  baselineScenario    PlanningScenario @relation("BaselineScenario", fields: [baselineScenarioId], references: [id], onDelete: Cascade)

  // Comparison scenarios
  comparisonScenarioIds String @map("comparison_scenario_ids_json") // JSON array of scenario IDs
  comparisonScenarios PlanningScenario[] @relation("ComparisonScenarios")

  // Comparison payload (complete comparison data)
  comparisonPayloadJson String @map("comparison_payload_json")

  // Interpretation
  interpretationNotes String?  @map("interpretation_notes_json") // JSON array of interpretation strings
  warnings            String?  @map("warnings_json") // JSON array of warning strings

  createdBy           String   @map("created_by")
  createdAt           DateTime @default(now()) @map("created_at")

  @@index([householdId, taxYear])
  @@index([baselineScenarioId])
  @@map("scenario_comparisons")
}

model ScenarioTemplate {
  id                  String   @id @default(cuid())

  // Template identity
  templateName        String   @unique @map("template_name")
  scenarioType        String   @map("scenario_type") // "roth_conversion" | "charitable" | "capital_gains" | etc.

  // Metadata
  name                String
  description         String

  // Template definition (JSON)
  requiredFields      String   @map("required_fields_json") // JSON array of required field names
  seedOverrides       String   @map("seed_overrides_json") // JSON array of partial ScenarioOverride objects
  seedAssumptions     String   @map("seed_assumptions_json") // JSON array of partial ScenarioAssumption objects
  linkedOpportunityTypes String @map("linked_opportunity_types_json") // JSON array of opportunity types

  // Control
  isActive            Boolean  @default(true) @map("is_active")
  displayOrder        Int      @default(0) @map("display_order")

  createdBy           String   @map("created_by")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@index([scenarioType])
  @@index([isActive, displayOrder])
  @@map("scenario_templates")
}

model ScenarioAuditEvent {
  id                  String   @id @default(cuid())

  // Event metadata
  eventType           String   @map("event_type") // "created" | "updated" | "calculated" | "validation_failed" | "recommended" | "archived" | "superseded" | "converted_to_report" | "converted_to_task"

  // Related scenario
  scenarioId          String   @map("scenario_id")
  scenario            PlanningScenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  // Actor
  actor               String
  actorType           String   @map("actor_type") // "advisor" | "system" | "client"

  // Changes (JSON snapshots)
  changesBefore       String?  @map("changes_before_json")
  changesAfter        String?  @map("changes_after_json")

  // Metadata
  metadata            String?  @map("metadata_json")

  // Request context
  ipAddress           String?  @map("ip_address")
  userAgent           String?  @map("user_agent")
  sessionId           String?  @map("session_id")

  timestamp           DateTime @default(now())

  @@index([scenarioId])
  @@index([eventType])
  @@index([actor])
  @@index([timestamp])
  @@map("scenario_audit_events")
}

// ==================== TAX CALCULATION RUNS (Phase 5A) ====================

model TaxCalculationRun {
  id                   String   @id @default(cuid())

  // Scenario reference
  scenarioId           String?  @map("scenario_id")
  scenario             PlanningScenario? @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  // Snapshot reference
  snapshotId           String   @map("snapshot_id")

  // Tax calculation context
  taxYear              Int      @map("tax_year")
  runType              String   @map("run_type") // "baseline" | "scenario"

  // Tax output (UI-friendly format)
  taxOutputJson        String   @map("tax_output_json")

  // Full calculation trace (for debugging and audit)
  intermediatesJson    String   @map("intermediates_json")
  traceJson            String   @map("trace_json")
  warningsJson         String?  @map("warnings_json")
  unsupportedItemsJson String?  @map("unsupported_items_json")
  executionOrder       String   @map("execution_order") // JSON array

  // Performance metrics
  computeTimeMs        Int      @map("compute_time_ms")

  createdAt            DateTime @default(now()) @map("created_at")

  @@index([scenarioId])
  @@index([snapshotId])
  @@index([taxYear])
  @@index([runType])
  @@map("tax_calculation_runs")
}
// ==================== INTERSTATE TAX MIGRATION CALCULATOR (Phase 1) ====================

model relocation_jurisdictions {
