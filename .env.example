# Farther Focus — AI Configuration
# Set these to enable AI-powered adaptive questioning and profile generation.
# When not set, the system falls back to the static 395-question bank and
# deterministic scoring engine.

# Your Anthropic API key (required for AI features)
AI_API_KEY=

# AI model to use (default: claude-sonnet-4-20250514)
AI_MODEL=claude-sonnet-4-20250514

# API base URL (default: https://api.anthropic.com)
AI_BASE_URL=https://api.anthropic.com

# Farther Prism — Database Configuration
# SQLite database URL (relative to project root)
DATABASE_URL="file:./dev.db"
