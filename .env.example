# ═══════════════════════════════════════════════════════════════════════════
# Farther Focus — AI Configuration
# ═══════════════════════════════════════════════════════════════════════════
#
# AI Gateway provider cascade: Zolo → Anthropic → template fallback
#   - If AI_ZOLO_KEY is set, all LLM calls route through AI Zolo first
#   - If AI_API_KEY is set, Anthropic is the fallback (or primary if no Zolo key)
#   - If neither is set, all AI features fall back to template-based generation
#
# Features powered by the AI Gateway:
#   - Risk profile: adaptive questions + AI-powered scoring
#   - Plan narratives: executive summary generation
#   - Email composer: insight-to-email drafts
#   - Report writer: AI-enhanced report sections
#   - Tax analyzer: AI-powered change analysis
#
# Gamma AI is independent — used for PDF/PPTX document generation.
# ═══════════════════════════════════════════════════════════════════════════

# MiniMax API key (primary AI provider for document processing & wealth tools)
MINIMAX_API_KEY=

# AI Zolo API key (OpenAI-compatible gateway — legacy/fallback)
AI_ZOLO_KEY=

# Anthropic API key (fallback provider)
AI_API_KEY=

# Anthropic model (default: claude-sonnet-4-20250514)
AI_MODEL=claude-sonnet-4-20250514

# Anthropic API base URL (default: https://api.anthropic.com)
AI_BASE_URL=https://api.anthropic.com

# Gamma AI API key (for presentation/document generation and PDF/PPTX export)
GAMMA_API_KEY=

# Farther Prism — Database Configuration
# SQLite database URL (relative to project root) for Prism/existing tools
# PostgreSQL URL for FMSS (Railway provides this automatically in production)
DATABASE_URL="file:./dev.db"

# ═══════════════════════════════════════════════════════════════════════════
# FMSS (Farther Market Scoring System) — API Configuration
# ═══════════════════════════════════════════════════════════════════════════
#
# FMSS requires multiple data source APIs for comprehensive market intelligence:
#   - Web Scraping: Bright Data (primary), Tavily (backup)
#   - Market Data: FMP (fundamentals), Finnhub (real-time)
#   - Alternative Data: Aletheia (sentiment), SOV.AI (signals)
#   - Economic Data: FRED (macro indicators), Alpha Vantage (forex/commodities)
#   - Global Data: Econdb (international economic data)
#
# All FMSS workers log to fmss_ingest_log table with full audit trail.
# ═══════════════════════════════════════════════════════════════════════════

# Web Scraping APIs
BRIGHT_DATA_API_KEY=           # Bright Data Web Unlocker (primary scraper)
TAVILY_API_KEY=                # Tavily Extract (backup scraper)

# Financial Market Data APIs
FMP_API_KEY=                   # Financial Modeling Prep — equity/ETF fundamentals
                               # Base URL: https://financialmodelingprep.com/stable
                               # Auth: append ?apikey=YOUR_KEY to all endpoints

FINNHUB_API_KEY=               # Finnhub — real-time market data, insider trades, earnings
                               # Base URL: https://finnhub.io/api/v1
                               # Auth: pass as query param ?token=YOUR_KEY

# Alternative & Sentiment Data
ALETHEIA_API_KEY=              # Aletheia — earnings call sentiment, analyst sentiment
SOV_AI_API_KEY=                # SOV.AI — social sentiment signals, unusual activity

# Economic & Macro Data
FRED_API_KEY=                  # FRED (Federal Reserve Economic Data) — macro indicators
                               # Base URL: https://api.stlouisfed.org/fred
                               # Auth: pass as query param ?api_key=YOUR_KEY

ALPHA_VANTAGE_API_KEY=         # Alpha Vantage — forex, commodities, economic indicators
                               # Base URL: https://www.alphavantage.co/query
                               # Auth: pass as query param ?apikey=YOUR_KEY

ECONDB_API_KEY=                # Econdb — international economic data
                               # Base URL: https://www.econdb.com/api
